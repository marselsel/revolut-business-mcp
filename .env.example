# ---- Revolut Business API (upstream credentials) ----
# Client ID from the API certificate you uploaded in Revolut Business → Settings → APIs.
REVOLUT_CLIENT_ID=

# The RSA private key matching the uploaded certificate. Provide the PEM contents
# (newlines may be \n-escaped) OR a file path. Treat it like banking credentials.
REVOLUT_PRIVATE_KEY=
# REVOLUT_PRIVATE_KEY_PATH=./privatecert.pem

# Refresh token from the one-time authorization:  npm run authorize
REVOLUT_REFRESH_TOKEN=

# JWT `iss` — the DOMAIN of the OAuth redirect URI you registered (e.g. example.com).
REVOLUT_JWT_ISSUER=

# sandbox (default — free, fake money) or production (needs a paid Revolut Grow plan).
# REVOLUT_ENVIRONMENT=sandbox

# Optional: persist a rotated refresh token across restarts (needs a persistent volume).
# REVOLUT_TOKEN_STORE_PATH=/data/revolut-refresh-token

# ---- Capabilities (choose your risk level) ----
# Master switch: when true, ONLY read tools are registered (overrides the flags below).
# REVOLUT_READ_ONLY=false

# Safe writes that do NOT move money (payment drafts, counterparties, webhooks, cards). Default: true
# REVOLUT_ENABLE_DRAFTS=true

# Money movement (pay/transfer/exchange) + irreversible deletes. IRREVERSIBLE. Default: false
# REVOLUT_ENABLE_PAYMENTS=false

# ---- MCP endpoint protection (inbound: client → /mcp) ----
# Static bearer token clients must send to reach /mcp. Generate a strong one:
#   openssl rand -hex 32
MCP_AUTH_TOKEN=

# Escape hatch: run WITHOUT auth on /mcp. Trusted local testing only.
# MCP_ALLOW_UNAUTHENTICATED=false

# ---- OAuth for /mcp (optional; required for the Claude app custom-connector UI) ----
# Set OAUTH_ISSUER to switch /mcp to OAuth 2.1 (takes precedence over MCP_AUTH_TOKEN).
# OAUTH_ISSUER=https://your-tenant.authkit.app
# OAUTH_RESOURCE=https://your-server.example.com
# SERVER_URL=https://your-server.example.com
# OAUTH_ALLOWED_EMAIL_DOMAINS=example.com
#
# Verify the access token's audience (aud) equals OAUTH_RESOURCE. Default: true — keep it.
# Setting it false makes the server accept ANY valid token from the issuer (a confused-deputy risk).
# OAUTH_VERIFY_AUDIENCE=true
# OAUTH_JWKS_URL=https://your-tenant.authkit.app/oauth2/jwks
# OAUTH_USERINFO_URL=https://your-tenant.authkit.app/oauth2/userinfo

# ---- Server ----
# Listen port. Your platform may inject this. Default: 8080
# PORT=8080

# Verbose logging (method/path/status only — never secrets or bodies). Default: false
# REVOLUT_DEBUG_LOGGING=false
